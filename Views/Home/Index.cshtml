<!-- ===================== HERO ===================== -->
<section class="hero" id="inicio">
    <div class="hero__slides">
        <div class="hero__slide active">
            <img src="~/images/hero/hero-1.jpg" alt="" loading="eager" fetchpriority="high" />
        </div>
        <div class="hero__slide">
            <img src="~/images/hero/hero-2.jpg" alt="" loading="eager" />
        </div>
        <div class="hero__slide">
            <img src="~/images/hero/hero-3.jpg" alt="" loading="eager" />
        </div>
        <div class="hero__slide">
            <img src="~/images/hero/hero-4.jpg" alt="" loading="eager" />
        </div>
        <div class="hero__slide">
            <img src="~/images/hero/hero-5.jpg" alt="" loading="eager" />
        </div>
    </div>
    <div class="hero__overlay"></div>
    <div class="container hero__inner">
        <span class="eyebrow reveal">Sistemas electrónicos de seguridad · Hermosillo, Sonora</span>
        <h1 class="hero__title reveal">
            Protegemos lo que <span class="accent">más importa</span><br />
            con experiencia y tecnología confiable.
        </h1>
        <p class="hero__subtitle reveal">
            Diseño, suministro, instalación y mantenimiento de sistemas de seguridad para empresas, industrias e instituciones. Más de 15 años protegiendo a nuestros clientes en Sonora.
        </p>
        <div class="hero__actions reveal">
            <a href="#contacto" class="btn btn--primary">Solicita una cotización</a>
            <a href="#servicios" class="btn btn--ghost">Conoce nuestros servicios</a>
        </div>

        <div class="hero__metrics reveal">
            <div class="metric">
                <span class="metric__value">+15</span>
                <span class="metric__label">Años de experiencia</span>
            </div>
            <div class="metric">
                <span class="metric__value">+20</span>
                <span class="metric__label">Proyectos realizados</span>
            </div>
            <div class="metric">
                <span class="metric__value">2010</span>
                <span class="metric__label">Año de fundación</span>
            </div>
        </div>
    </div>
    <a href="#servicios" class="hero__scroll" aria-label="Bajar a servicios">
        <span></span>
    </a>
</section>

<!-- ===================== SERVICIOS ===================== -->
<section class="section" id="servicios">
    <div class="container">
        <header class="section__head reveal">
            <span class="eyebrow">Nuestros servicios</span>
            <h2 class="section__title">Soluciones integrales de seguridad electrónica</h2>
            <p class="section__lead">Brindamos soluciones a la medida con suministro, instalación y mantenimiento de sistemas de seguridad, garantizando la protección de personas, bienes e instalaciones de nuestros clientes.</p>
        </header>

        <div class="grid grid--3">
            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c1.5 3 4 4.5 4 8a4 4 0 11-8 0c0-2 1-3.5 2-5"/><path d="M10 14c.5 1.5 2 2.5 4 2"/></svg>
                </div>
                <h3 class="card__title">Sistemas contra incendio</h3>
                <p class="card__text">Suministro, instalación y mantenimiento de detectores de humo, calor y gases, integrados a paneles certificados y sistemas de evacuación.</p>
            </article>

            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="6" width="14" height="10" rx="1.5"/><path d="M17 9l4-2v10l-4-2z"/><circle cx="10" cy="11" r="1.2" fill="currentColor"/></svg>
                </div>
                <h3 class="card__title">Sistemas de CCTV</h3>
                <p class="card__text">Cámaras IP de alta resolución, grabación inteligente y monitoreo remoto. Suministro, instalación y mantenimiento profesional.</p>
            </article>

            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="11" r="3"/><path d="M9 17h6"/></svg>
                </div>
                <h3 class="card__title">Control de acceso</h3>
                <p class="card__text">Sistemas biométricos, lectoras de tarjetas y reconocimiento facial para gestionar accesos de forma segura y confiable.</p>
            </article>

            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12h4l2-7 4 14 2-7h6"/></svg>
                </div>
                <h3 class="card__title">Cableado estructurado</h3>
                <p class="card__text">Suministro e instalación de redes de voz y datos. Infraestructura de comunicación confiable para empresas e instituciones.</p>
            </article>

            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18M3 12h18M3 18h18"/><path d="M7 3v18M13 3v18M19 3v18"/></svg>
                </div>
                <h3 class="card__title">Cercas electrificadas</h3>
                <p class="card__text">Suministro, instalación y mantenimiento de sistemas perimetrales eléctricos para protección externa de propiedades.</p>
            </article>

            <article class="card reveal">
                <div class="card__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7l9-4 9 4-9 4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/></svg>
                </div>
                <h3 class="card__title">Suministros industriales</h3>
                <p class="card__text">Componentes y materiales especializados para proyectos de seguridad e instalaciones técnicas industriales.</p>
            </article>
        </div>
    </div>
</section>

