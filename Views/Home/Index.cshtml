            </ul>
        </div>

        <div class="image-frame reveal">
            <img src="https://web-assets.esetstatic.com/wls/2018/09/Descubren-vulnerabilidad-cr%C3%ADtica-c%C3%A1maras-seguridad-CCTV.jpg" alt="Centro de monitoreo profesional" loading="lazy" />
