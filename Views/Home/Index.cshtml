<!-- ===================== CONTACTO ===================== -->
<section class="section" id="contacto">
    <div class="container grid grid--2 grid--gap">
        <div class="reveal">
            <span class="eyebrow">Contacto</span>
            <h2 class="section__title">Hablemos de tu proyecto</h2>
            <p class="section__lead">Cuéntanos qué necesitas y un asesor se pondrá en contacto contigo en menos de 24 horas.</p>

            <ul class="contact-info">
                <li><strong>Teléfono:</strong> +52 662 142 4966</li>
                <li><strong>Email:</strong> vayo28@hotmail.com</li>
                <li><strong>Dirección:</strong> De Los Racimos 20, La Verbena, Hermosillo, Sonora</li>
                <li><strong>Horario:</strong> Disponible a Cotizaciones las 24hrs</li>
            </ul>
        </div>

        <form class="form reveal" id="contactForm" novalidate>
            <div class="form__row">
                <label>
                    <span>Nombre</span>
                    <input type="text" name="nombre" required />
                </label>
                <label>
                    <span>Teléfono</span>
                    <input type="tel" name="telefono" required />
                </label>
            </div>
            <label>
                <span>Email</span>
                <input type="email" name="email" required />
            </label>
            <label>
                <span>Servicio de interés</span>
                <select name="servicio" required>
                    <option value="">Selecciona una opción</option>
                    <option>Sistemas contra incendio</option>
                    <option>Sistemas de CCTV</option>
                    <option>Control de acceso</option>
                    <option>Cableado estructurado</option>
                    <option>Cercas electrificadas</option>
                    <option>Suministros industriales</option>
                </select>
            </label>
            <label>
                <span>Mensaje</span>
                <textarea name="mensaje" rows="4" required></textarea>
            </label>
            <button type="submit" class="btn btn--primary btn--block">Enviar solicitud</button>
            <p class="form__status" id="formStatus"></p>
        </form>
    </div>
</section>
